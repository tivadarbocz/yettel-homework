# Auto detect text files and normalize line endings
* text=auto

# Force LF for Unix scripts
*.sh text eol=lf
mvnw text eol=lf

# Force CRLF for Windows scripts
*.cmd text eol=crlf
*.bat text eol=crlf
mvnw.cmd text eol=crlf

# Java sources
*.java text
*.xml text
*.yml text
*.yaml text
*.properties text

# Docker
Dockerfile text eol=lf
*.dockerfile text eol=lf

# Mark binaries
*.jar binary
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.ico binary

# Prevent diff noise for generated files
target/** linguist-generated=true